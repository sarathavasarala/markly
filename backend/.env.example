# SQLite database owned by the backend
# In Azure App Service, use persistent storage such as /home/data/markly.db
MARKLY_DB_PATH=./markly.db

# Azure OpenAI Configuration
# Required for AI enrichment. Embeddings can be stored for future semantic search.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_NANO_DEPLOYMENT_NAME=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-12-01-preview

# Optional custom override deployment for Signal daily brief generation
# If left unset, Signal will fall back to the default Azure OpenAI settings above.
# SIGNAL_AZURE_OPENAI_API_KEY=your-custom-signal-api-key
# SIGNAL_AZURE_OPENAI_ENDPOINT=https://your-custom-signal-resource.openai.azure.com/
# SIGNAL_AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-more-powerful
# SIGNAL_AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Feature flags
ENABLE_EMBEDDINGS=true
ENABLE_SEMANTIC_SEARCH=false
SIGNAL_HUMANIZER_ENABLED=true

# Optional Daily Brief tracing. Keep disabled until Langfuse credentials are set.
BRIEF_TRACING_ENABLED=false
BRIEF_TRACE_SINK=noop
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Google OAuth + allowlisted access
CRON_SECRET=a-secure-random-token-for-github-actions-cron
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_REDIRECT_BASE_URL=http://localhost:5173
# Required in production. Comma-separated Google accounts allowed to sign in.
# An empty value denies all logins (fail-closed). Add your email here.
ALLOWED_EMAILS=you@example.com,friend@example.com

# Local development login bypass.
# When set to true (and APP_ENV is not "test"), Google OAuth is skipped and every
# request is authenticated as the dev bypass user. Leave unset/false in any
# deployed environment.
DEV_BYPASS_AUTH=false
# Optional - account the bypass logs in as (falls back to a generic dev user).
# DEV_BYPASS_EMAIL=you@example.com
# DEV_BYPASS_NAME=Your Name

# Optional - Jina Reader API for better web scraping/content extraction
# Get a free key at https://jina.ai/reader/
JINA_READER_API_KEY=

# Optional - Parallel Search MCP API Key for higher search limits
# Get a key at https://platform.parallel.ai
PARALLEL_API_KEY=

# Research provider for the daily brief research step (stage 6).
# "parallel" (default) - Parallel Search MCP server (requires PARALLEL_API_KEY for higher limits).
# "azure"    - Azure OpenAI native web_search tool (Bing-backed; incurs Bing pricing per call;
#              data flows outside your Azure compliance/geo boundary).
# Restart the backend after changing this value.
RESEARCH_PROVIDER=parallel

# Reasoning effort for Azure native web_search research (low/medium/high). Default: low.
# "low" = fast, shallow lookups. "medium" = opens and reads pages. "high" = deep, slow.
# Only applies when RESEARCH_PROVIDER=azure.
AZURE_RESEARCH_REASONING_EFFORT=low


# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
FLASK_SECRET_KEY=generate-a-random-secret-key
